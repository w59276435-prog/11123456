# 应用配置
APP_NAME="Personal Info Management System"
APP_VERSION="2.0"
DEBUG=True

# 数据库
DATABASE_URL=sqlite:///./data.db
# PostgreSQL 示例: postgresql://user:password@localhost/dbname
# MySQL 示例: mysql+pymysql://user:password@localhost/dbname

# 加密
PI_ENC_KEY=your-32-char-encryption-key-change-in-prod
SECRET_KEY=your-secret-key-for-jwt-tokens-change-in-prod

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# 文件上传
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=["jpg", "jpeg", "png", "bmp", "webp", "gif"]

# 邮件（可选）
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@company.com

# 日志
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
